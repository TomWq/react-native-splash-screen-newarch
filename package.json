{
  "name": "react-native-splash-screen-newarch",
  "version": "2.0.0",
  "description": "A splash screen for react-native, hide when application loaded ,it works on iOS and Android.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "android/src",
    "android/build.gradle",
    "android/proguard-rules.pro",
    "ios/RNSplashScreen.h",
    "ios/RNSplashScreen.mm",
    "ios/RNSplashScreenManager.swift",
    "src",
    "app.plugin.js",
    "index.js",
    "index.d.ts",
    "react-native.config.js",
    "react-native-splash-screen-newarch.podspec",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "codegenConfig": {
    "name": "rnsplashscreen",
    "type": "modules",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.tomwq.rnsplashscreen"
    }
  },
  "scripts": {
    "test": "node --check index.js && node --check app.plugin.js && node scripts/test-plugin.js",
    "pack:dry-run": "npm pack --dry-run",
    "npm:login": "npm login --auth-type=web --registry=https://registry.npmjs.org/",
    "publish:dry-run": "npm publish --dry-run",
    "publish:npm": "npm publish --access public",
    "release:patch": "npm version patch && npm run publish:npm",
    "release:minor": "npm version minor && npm run publish:npm",
    "release:major": "npm version major && npm run publish:npm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomWq/react-native-splash-screen-newarch.git"
  },
  "keywords": [
    "react-native",
    "react-native-component",
    "splash-screen",
    "splashscreen",
    "splash",
    "launch-screen",
    "launchscreen",
    "android",
    "ios",
    "expo",
    "expo-config-plugin",
    "new-architecture",
    "turbo-module",
    "fullscreen"
  ],
  "author": "TomWq",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TomWq/react-native-splash-screen-newarch/issues"
  },
  "peerDependencies": {
    "react-native": "*",
    "expo": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "homepage": "https://github.com/TomWq/react-native-splash-screen-newarch#readme"
}
